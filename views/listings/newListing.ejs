<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Listing</title>
</head>
<body>
    <h3>Add New Listing</h3>
    <form method="POST" action="/listings">
        <input type="text" name="listing[title]" placeholder="Title"><br><br>
        <textarea name="listing[description]" placeholder="Description"></textarea><br><br>
        <input type="text" name="listing[image]" placeholder="Image URL"><br><br>
        <input type="number" name="listing[price]" placeholder="Price"><br><br>
        <input type="text" name="listing[location]" placeholder="Location"><br><br>
        <input type="text" name="listing[country]" placeholder="country"><br><br>
        <button>Add new listing</button>
    </form>
</body>
</html>