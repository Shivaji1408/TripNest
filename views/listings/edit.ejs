<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit listing</title>
</head>
<body>
    <h3>Edit this Listing</h3>
    <form method="POST" action="/listings/<%= listing._id %>?_method=PUT">
        <input type="text" name="listing[title]" value="<%= listing.title %>" placeholder="Title"><br><br>
        <textarea name="listing[description]" placeholder="Description"><%= listing.description %></textarea><br><br>
        <input type="text" name="listing[image]" value="<%= listing.image.url %>" placeholder="Image URL"><br><br>
        <input type="number" name="listing[price]" value="<%= listing.price %>" placeholder="Price"><br><br>
        <input type="text" name="listing[location]" value="<%= listing.location %>" placeholder="Location"><br><br>
        <input type="text" name="listing[country]" value="<%= listing.country %>" placeholder="country"><br><br>
        <button>Update this listing</button>
    </form>
</body>
</html>